# Copier ce fichier en .env et remplir les valeurs

# Serveur
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/maison-luxe
# Ou MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/maison-luxe

# JWT
JWT_SECRET=votre_secret_jwt_tres_long_et_securise_ici
JWT_EXPIRE=7d

# Orange Money Mali (API CinetPay - partenaire Orange Mali)
# Créer un compte sur https://cinetpay.com
CINETPAY_API_KEY=votre_api_key_cinetpay
CINETPAY_SITE_ID=votre_site_id_cinetpay
CINETPAY_SECRET_KEY=votre_secret_key_cinetpay
CINETPAY_NOTIFY_URL=https://votre-domaine.com/api/payments/notify
CINETPAY_RETURN_URL=https://votre-domaine.com/commande/succes
CINETPAY_CANCEL_URL=https://votre-domaine.com/commande/annule

# Frontend URL (pour CORS)
FRONTEND_URL=http://localhost:3000
